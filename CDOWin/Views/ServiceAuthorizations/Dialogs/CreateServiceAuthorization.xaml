<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CDOWin.Views.ServiceAuthorizations.Dialogs.CreateServiceAuthorization"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDOWin.Views.ServiceAuthorizations.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CDOWin.Controls"
    mc:Ignorable="d">

    <Grid Style="{StaticResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Case ID + Tier + Counselor (Non Editable) -->
        <controls:LabelPair Grid.Row="0" Grid.Column="0"
                            Label="Issued By" 
                            Value="{x:Bind ViewModel.Client.CounselorReference.Name}"/>
        <controls:LabelPair Grid.Row="0" Grid.Column="1"
                            Label="Tier Level" 
                            Value="{x:Bind ViewModel.Client.Status}"/>
        <controls:LabelPair Grid.Row="0" Grid.Column="2"
                            Label="Case ID" 
                            Value="{x:Bind ViewModel.Client.CaseID}"/>

        <!-- Row 1: Border + Content -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Style="{StaticResource DialogBorderWithDividerStyle}">
            <Grid Style="{StaticResource DialogScrollViewerInnerGridStyle}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0: Office Address -->
                <AutoSuggestBox x:Name="OfficeSuggestBox"
                                Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" 
                                Header="Office Address"
                                TextChanged="OfficeSuggestBox_TextChanged"
                                QuerySubmitted="OfficeSuggestBox_QuerySubmitted"
                                SuggestionChosen="OfficeSuggestBox_SuggestionChosen"/>

                <!-- Row 1: SA Number + Start Date + End Date -->
                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                         Header="SA Number"
                         MaxLength="15"
                         Tag="{x:Bind local:Field.SaNumber}"
                         TextChanged="TextChanged"/>

                <CalendarDatePicker x:Name="StartDatePicker"
                                    Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                    HorizontalAlignment="Stretch"
                                    Header="Start Date"
                                    Tag="{x:Bind local:DateType.StartDate}"
                                    DateChanged="DatePicker_DateChanged"/>

                <CalendarDatePicker x:Name="EndDatePicker"
                                    Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
                                    HorizontalAlignment="Stretch"
                                    Header="End Date"
                                    Tag="{x:Bind local:DateType.EndDate}"
                                    DateChanged="DatePicker_DateChanged"/>

                <!-- Row 2: Description -->
                <AutoSuggestBox x:Name="DescriptionSuggestBox"
                                Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6" 
                                Header="Description"
                                TextChanged="DescriptionSuggestBox_TextChanged"
                                QuerySubmitted="DescriptionSuggestBox_QuerySubmitted"
                                SuggestionChosen="DescriptionSuggestBox_SuggestionChosen"/>
                
                <!-- Row 3: U/M + Cost-->
                <TextBox x:Name="UMBox"
                         Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                         Header="U/M"
                         MaxLength="9"
                         Tag="{x:Bind local:Field.UoM}"
                         TextChanged="TextChanged"/>
                <NumberBox x:Name="NumberBox"
                           Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" 
                           Header="Unit Cost" PlaceholderText="0.00" 
                           ValueChanged="NumberBox_ValueChanged"/>
            </Grid>
        </Border>
    </Grid>
</Page>
