<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Backstage.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Backstage.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="16,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Padding="0,0,0,8"
                   x:Name="HelloText" FontSize="32" FontWeight="Black"/>
        <ScrollViewer Grid.Row="1"
                      VerticalScrollMode="Enabled" 
                      HorizontalScrollMode="Disabled">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Today" FontSize="16" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <!-- Recent Clients Card -->
                        <Grid Style="{StaticResource CardContainerGridStyle}">

                            <!-- Inner Grid -->
                            <Grid Style="{StaticResource CardInnerGridStyle}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Text="Clients" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- Recent Notes Card -->
                        <Grid Style="{StaticResource CardContainerGridStyle}">

                            <!-- Inner Grid -->
                            <Grid Style="{StaticResource CardInnerGridStyle}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Text="Notes" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </Grid>
                        </Grid>
                        
                        <!-- Recent Reminders Card -->
                        <Grid Style="{StaticResource CardContainerGridStyle}">

                            <!-- Inner Grid -->
                            <Grid Style="{StaticResource CardInnerGridStyle}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Text="Reminders" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Billing" FontSize="16" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <!-- Service Authorizations Card -->
                        <Grid Style="{StaticResource CardContainerGridStyle}">

                            <!-- Inner Grid -->
                            <Grid Style="{StaticResource CardInnerGridStyle}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Text="Service Authorizations" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </Grid>
                        </Grid>

                        <!-- Placement Card -->
                        <Grid Style="{StaticResource CardContainerGridStyle}">

                            <!-- Inner Grid -->
                            <Grid Style="{StaticResource CardInnerGridStyle}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Text="Placements" Style="{StaticResource SubtitleTextBlockStyle}"/>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="10">
                    <TextBlock Text="Stale Clients" FontSize="16" FontWeight="SemiBold"/>
                    <ItemsRepeater>
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
