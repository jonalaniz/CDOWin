<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- DialogRootGridStyle -->
    <Style x:Key="DialogRootGridStyle" TargetType="Grid">
        <Setter Property="Width" Value="490"/>
        <Setter Property="RowSpacing" Value="12"/>
        <Setter Property="ColumnSpacing" Value="16"/>
    </Style>

    <!-- DialogBorderWithDividerStyle -->
    <Style x:Key="DialogBorderWithDividerStyle" TargetType="Border">
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentAAFillColorDisabled}"/>
    </Style>

    <!-- DialogScrollViewerStyle -->
    <Style x:Key="DialogScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Padding" Value="0,16,0,0"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <!-- DialogScrollViewerInnerGridStyle -->
    <Style x:Key="DialogScrollViewerInnerGridStyle" TargetType="Grid">
        <Setter Property="RowSpacing" Value="12"/>
        <Setter Property="ColumnSpacing" Value="16"/>
    </Style>

    <!-- DialogExpanderStyle -->
    <Style x:Key="DialogExpanderStyle" TargetType="Expander">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="IsExpanded" Value="False"/>
    </Style>

    <!-- ExpanderRootGridStyle -->
    <Style x:Key="ExpanderRootGridStyle" TargetType="Grid">
        <Setter Property="Width" Value="454"/>
        <Setter Property="RowSpacing" Value="10"/>
        <Setter Property="ColumnSpacing" Value="12"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>
</ResourceDictionary>
