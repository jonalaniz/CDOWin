<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CDOWin.Views.Clients.Dialogs.CreateNote"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Width="460" RowSpacing="10" ColumnSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Row 0: Date Picker -->
        <DatePicker Grid.Row="0" x:Name="DatePicker" Margin="0" Padding="0"
                    HorizontalAlignment="Stretch" Header="Date"
                    DateChanged="DatePicker_DateChanged"/>

        <!-- Row 1: Time Picker -->
        <TimePicker Grid.Row="1" x:Name="TimePicker" Margin="0" Padding="0"
                    HorizontalAlignment="Stretch" Header="Time"
                    TimeChanged="TimePicker_TimeChanged"/>
        
        <!-- Row 1: Notes -->
        <TextBox Grid.Row="2" MaxHeight="200"
                 Style="{StaticResource MultiLineTextBoxStyle}"
                 Header="Note" TextChanged="LabeledMultiLinePair_TextChanged"/>
    </Grid>
</Page>
