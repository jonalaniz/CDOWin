<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CDOWin.Views.Counselors.CounselorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:counselors="using:CDO.Core.DTOs.Counselors"
    xmlns:clients="using:CDO.Core.DTOs.Clients"
    mc:Ignorable="d">

    <Grid>
        <!-- Columns -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="212"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="336"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Column -->
        <Grid Style="{StaticResource ContentRightBorderStyle}">

            <!-- Rows -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Columns -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Style="{StaticResource PageTitleStyle}"
                       Text="Counselors"/>
            
            <!-- CommandBar -->
            <CommandBar Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource CommandBarDefaultStyle}">
                <AppBarButton Width="56"
                              IsCompact="False" 
                              ToolTipService.ToolTip="New Counselor"
                              Click="NewCounselor_ClickAsync">
                    <FontIcon Style="{StaticResource SingleIconFontStyle}"
                              Glyph="&#xE710;"/>
                </AppBarButton>
            </CommandBar>

            <!-- Search Bar -->
            <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                     Margin="8,0,8,8" 
                     PlaceholderText="Filter Counselors"
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            
            <!-- Counselors List -->
            <ListView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                      Style="{StaticResource SummaryListViewStyle}"
                      SelectedItem="{x:Bind ViewModel.SelectedSummary, Mode=TwoWay}"
                      ItemsSource="{x:Bind ViewModel.Filtered, Mode=OneWay}"
                      ItemClick="ListView_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="counselors:CounselorSummary">
                        <Grid Margin="0,8,8,8">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="{x:Bind Name}"
                                       FontWeight="Bold" 
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Row="1" 
                                       Text="{x:Bind FormattedCaseLoadID}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock Grid.Row="2" 
                                       Text="{x:Bind Phone}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Grid>                        
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Status Bar -->
            <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                  Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <TextBlock Style="{StaticResource ListStatusBarStyle}">
                    <Run Text="{x:Bind ViewModel.Filtered.Count, Mode=OneWay}"/>
                    <Run Text="Counselors"/>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Middle Column -->
        <Grid Grid.Column="1" BorderThickness="0,0,1,0"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              Visibility="{x:Bind ViewModel.Selected, Mode=OneWay, Converter={StaticResource NullToVisability}}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="{x:Bind ViewModel.Selected.Name, Mode=OneWay}"
                       Style="{StaticResource PageTitleStyle}"/>

            <!-- CommandBar -->
            <CommandBar Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource CommandBarDefaultStyle}">
                <AppBarButton Width="56" 
                              IsCompact="False" 
                              ToolTipService.ToolTip="More">
                    <AppBarButton.Icon>
                        <FontIcon Style="{StaticResource SingleIconFontStyle}"
                                  Glyph="&#xE712;"/>
                    </AppBarButton.Icon>
                    <AppBarButton.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuFlyoutItem Text="Delete..." 
                                            Click="Delete_MenuFlyoutItem_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Style="{StaticResource DeleteSymbolIcon}"/>
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
            </CommandBar>

            <!-- Clients Table -->
            <ListView x:Name="ListView"
                      Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                      ItemsSource="{x:Bind ViewModel.Clients, Mode=OneWay}"
                      Style="{StaticResource DataTableStyle}">

                <!-- Header -->
                <ListView.Header>
                    <Grid Style="{StaticResource DataTableHeaderStyle}">

                        <interactivity:Interaction.Behaviors>
                            <behaviors:StickyHeaderBehavior/>
                        </interactivity:Interaction.Behaviors>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" 
                                   Text="Name" 
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" 
                                   Text="Case ID" 
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" 
                                   Text="Address" 
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" 
                                   Text="Phone" 
                                   FontWeight="SemiBold"/>
                    </Grid>
                </ListView.Header>

                <!-- Content -->
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="clients:ClientSummary">
                        <Grid Padding="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{x:Bind FormattedName}"
                                           TextWrapping="WrapWholeWords" FontWeight="Bold"/>
                                <Button Grid.Column="1" 
                                        Style="{StaticResource AccentButtonStyle}"
                                        Tag="{x:Bind Id}"
                                        Click="GoToClient_Click">
                                    <FontIcon Glyph="&#xE76C;"/>
                                </Button>
                            </Grid>
                            <TextBlock Grid.Column="1" 
                                       Text="{x:Bind CaseID}"/>
                            <TextBlock Grid.Column="2" 
                                       Text="{x:Bind FormattedAddress}" 
                                       TextWrapping="WrapWholeWords"/>
                            <TextBlock Grid.Column="3" 
                                       Text="{x:Bind Phone}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Status Bar -->
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                <TextBlock Style="{StaticResource ListStatusBarStyle}">
                    <Run Text="{x:Bind ViewModel.Clients.Count, Mode=OneWay}"/>
                    <Run Text="Client(s)"/>
                </TextBlock>
            </Grid>
        </Grid>
        
        <!-- Right Column -->
        <Frame x:Name="InspectorFrame"
               Grid.Column="2"
               IsNavigationStackEnabled="False"/>
    </Grid>
</Page>
