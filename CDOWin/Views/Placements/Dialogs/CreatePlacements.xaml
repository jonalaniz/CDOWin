<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CDOWin.Views.Placements.Dialogs.CreatePlacements"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDOWin.Views.Placements.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CDOWin.Controls"
    xmlns:models="using:CDO.Core.Models"
    mc:Ignorable="d">

    <Grid Style="{StaticResource DialogRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Case ID + Tier + Counselor (Non Editable) -->
        <controls:LabelPair Grid.Row="0" Grid.Column="0" 
                            Label="Issued By" 
                            Value="{x:Bind ViewModel.Client.CounselorReference.Name}"/>
        <controls:LabelPair Grid.Row="0" Grid.Column="1"
                            Label="Tier Level" 
                            Value="{x:Bind ViewModel.Client.Status}"/>
        <controls:LabelPair Grid.Row="0" Grid.Column="2"
                            Label="Case ID" 
                            Value="{x:Bind ViewModel.Client.CaseID}"/>
        
        <!-- Row 1: Border + Content -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Style="{StaticResource DialogBorderWithDividerStyle}">
            <ScrollViewer Style="{StaticResource DialogScrollViewerStyle}">
                <Grid Style="{StaticResource DialogScrollViewerInnerGridStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Employer Data -->
                    <Expander Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" 
                              Header="Employer Information"
                              Style="{StaticResource DialogExpanderStyle}">
                        <Grid Style="{StaticResource ExpanderRootGridStyle}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Row 0: Autosuggest Box + Phone -->
                            <AutoSuggestBox x:Name="EmployerAutoSuggest"
                                            Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" 
                                            Header="Employer Name"
                                            SuggestionChosen="EmployerAutoSuggest_SuggestionChosen"
                                            TextChanged="EmployerAutoSuggest_TextChanged">
                                <AutoSuggestBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Employer">
                                        <TextBlock Text="{x:Bind Name}"/>
                                    </DataTemplate>
                                </AutoSuggestBox.ItemTemplate>
                            </AutoSuggestBox>

                            <TextBox x:Name="EmployerPhoneTextBox"
                                     Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2" 
                                     Header="Employer Phone" 
                                     MaxLength="50" 
                                     Tag="{x:Bind local:UpdateField.EmployerPhone}"
                                     TextChanged="TextBox_TextChanged"/>

                            <!-- Row 1: Address 1 + 2 -->
                            <TextBox x:Name="AddressTextBox"
                                     Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" 
                                     Header="Address" 
                                     MaxLength="50"  
                                     Tag="{x:Bind local:UpdateField.Address1}"
                                     TextChanged="TextBox_TextChanged"/>
                            <TextBox x:Name="Address2TextBox"
                                     Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" 
                                     Header="Apt, ste, etc." 
                                     MaxLength="50"
                                     Tag="{x:Bind local:UpdateField.Address2}"
                                     TextChanged="TextBox_TextChanged"/>
                            
                            <!-- Row 2: City + State + Zip -->
                            <TextBox x:Name="CityTextBox"
                                     Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                                     Header="City" 
                                     MaxLength="25"
                                     Tag="{x:Bind local:UpdateField.City}"
                                     TextChanged="TextBox_TextChanged"/>
                            <StackPanel Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="1" 
                                        Spacing="8">
                                <TextBlock Text="State"/>
                                <DropDownButton x:Name="StateDropDownButton"
                                                Style="{StaticResource DropDownButtonStyle}"/>
                            </StackPanel>
                            <TextBox x:Name="ZipTextBox"
                                     Grid.Row="2" Grid.Column="5" 
                                     Header="Zip" 
                                     MaxLength="12" 
                                     Tag="{x:Bind local:UpdateField.Zip}"
                                     TextChanged="TextBox_TextChanged"/>

                            <!-- Row 3: Supervisor + Supervisor Phone -->
                            <TextBox x:Name="SupervisorTextBox"
                                     Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" 
                                     Header="Supervisor"
                                     MaxLength="50" 
                                     Tag="{x:Bind local:UpdateField.SupervisorName}"
                                     TextChanged="TextBox_TextChanged"/>
                            <TextBox x:Name="SPhoneBox"
                                     Grid.Row="3" Grid.Column="3" Grid.ColumnSpan="3" 
                                     Header="Supervisor Phone"
                                     MaxLength="50"
                                     Tag="{x:Bind local:UpdateField.SupervisorPhone}"
                                     TextChanged="TextBox_TextChanged"/>

                            <!-- Row 4: Supervisor Email -->
                            <TextBox x:Name="SEmailBox"
                                     Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="6" 
                                     Header="Supervisor Email"
                                     MaxLength="50" 
                                     Tag="{x:Bind local:UpdateField.SupervisorEmail}"
                                     TextChanged="TextBox_TextChanged"/>

                            <!-- Row 5: Website -->
                            <TextBox x:Name="WebsiteTextBox"
                                     Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="6" 
                                     Header="Website"
                                     MaxLength="225"
                                     Tag="{x:Bind local:UpdateField.Website}"
                                     TextChanged="TextBox_TextChanged"/>
                        </Grid>
                    </Expander>

                    <!-- Row 1: Position + Hire & End Dates -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                                Spacing="8">
                        <TextBlock Text="Service Authorization"/>
                        <DropDownButton x:Name="SANumberDropDownButton"
                                        Style="{StaticResource DropDownButtonStyle}"
                                        Content="Select an SA"/>
                    </StackPanel>
                    <CalendarDatePicker x:Name="HireDatePicker"
                                        Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"
                                        HorizontalAlignment="Stretch"
                                        Header="Hire Date"
                                        Tag="{x:Bind local:UpdateField.HireDate}"
                                        DateChanged="DatePicker_DateChanged">
                        <CalendarDatePicker.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Clear Date" 
                                                Tag="{x:Bind local:UpdateField.HireDate}"
                                                Click="MenuFlyoutItem_Click"/>
                            </MenuFlyout>
                        </CalendarDatePicker.ContextFlyout>
                    </CalendarDatePicker>
                    <CalendarDatePicker x:Name="EndDatePicker"
                                        Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
                                        HorizontalAlignment="Stretch"
                                        Header="End Date"
                                        Tag="{x:Bind local:UpdateField.EndDate}"
                                        DateChanged="DatePicker_DateChanged">
                        <CalendarDatePicker.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Clear Date"
                                                Tag="{x:Bind local:UpdateField.EndDate}"
                                                Click="MenuFlyoutItem_Click"/>
                            </MenuFlyout>
                        </CalendarDatePicker.ContextFlyout>
                    </CalendarDatePicker>

                    <!-- Row 2: Position + Hours Working + Wage -->
                    <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                             Header="Position"
                             MaxLength="50" 
                             Tag="{x:Bind local:UpdateField.Position}"
                             TextChanged="TextBox_TextChanged"/>
                    <TextBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" 
                             Header="Hours Working"
                             MaxLength="255" 
                             Tag="{x:Bind local:UpdateField.HoursWorking}"
                             TextChanged="TextBox_TextChanged"/>
                    <TextBox Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="2" 
                             Header="Wage"
                             MaxLength="255"
                             Tag="{x:Bind local:UpdateField.Wage}"
                             TextChanged="TextBox_TextChanged"/>

                    <!-- Rows 3 & 4: First 5 days -->
                    <CalendarDatePicker Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                        HorizontalAlignment="Stretch"
                                        Header="Day 1"
                                        Tag="{x:Bind local:UpdateField.Day1}"
                                        DateChanged="DatePicker_DateChanged"/>
                    <CalendarDatePicker Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2"
                                        HorizontalAlignment="Stretch"
                                        Header="Day 2"
                                        Tag="{x:Bind local:UpdateField.Day2}"
                                        DateChanged="DatePicker_DateChanged"/>
                    <CalendarDatePicker Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="2"
                                        HorizontalAlignment="Stretch"
                                        Header="Day 3"
                                        Tag="{x:Bind local:UpdateField.Day3}"
                                        DateChanged="DatePicker_DateChanged"/>
                    <CalendarDatePicker Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                                        HorizontalAlignment="Stretch"
                                        Header="Day 4"
                                        Tag="{x:Bind local:UpdateField.Day4}"
                                        DateChanged="DatePicker_DateChanged"/>
                    <CalendarDatePicker Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" 
                                        HorizontalAlignment="Stretch"
                                        Header="Day 5"
                                        Tag="{x:Bind local:UpdateField.Day5}"
                                        DateChanged="DatePicker_DateChanged"/>
                    
                    <!-- Row 5: Employee Benefits -->
                    <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="6" 
                             Header="Employee Benefits"
                             MaxLength="255" 
                             Style="{StaticResource MultiLineTextBoxStyle}" 
                             Tag="{x:Bind local:UpdateField.Benefits}"
                             TextChanged="TextBox_TextChanged"/>
                    
                    <!-- Row 6: Job Duties -->
                    <TextBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="6" 
                             Header="Description of Job Duties"
                             MaxLength="255" 
                             Style="{StaticResource MultiLineTextBoxStyle}" 
                             Tag="{x:Bind local:UpdateField.JobDuties}"
                             TextChanged="TextBox_TextChanged"/>

                    <!-- Row 7: Work Schedule -->
                    <TextBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="6" 
                             Header="Description of Work Schedule"
                             MaxLength="255" 
                             Style="{StaticResource MultiLineTextBoxStyle}" 
                             Tag="{x:Bind local:UpdateField.WorkSchedule}"
                             TextChanged="TextBox_TextChanged"/>

                    <!-- Row 8: Work Environment -->
                    <TextBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="6" 
                             Header="Description of Work Environment"
                             MaxLength="255" 
                             Style="{StaticResource MultiLineTextBoxStyle}" 
                             Tag="{x:Bind local:UpdateField.WorkEnvironment}"
                             TextChanged="TextBox_TextChanged"/>

                    <!-- Row 9: Accommodations -->
                    <TextBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="6" 
                             Header="Accommodations"
                             MaxLength="255" 
                             Style="{StaticResource MultiLineTextBoxStyle}" 
                             Tag="{x:Bind local:UpdateField.Accommodations}"
                             TextChanged="TextBox_TextChanged"/>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
